drop database ux;
CREATE DATABASE ux;

-- Usar la base de datos
USE ux;

CREATE TABLE Peliculas (
    Peliculas_ID INT PRIMARY KEY AUTO_INCREMENT,
    Titulo VARCHAR(100),
    Contenido TEXT,
    Puntuacion INT
);


-- Crear la tabla de resenas
CREATE TABLE Resenas (
    Resenas_ID INT PRIMARY KEY AUTO_INCREMENT,
    Usuario VARCHAR(20),
    comentario TEXT,
    Puntuacion INT
);

CREATE TABLE Peliculas_Resenas (
    Peliculas_ID INT,
    Resenas_ID INT,
    PRIMARY KEY (Peliculas_ID, Resenas_ID),
    FOREIGN KEY (Peliculas_ID) REFERENCES Peliculas(Peliculas_ID),
    FOREIGN KEY (Resenas_ID) REFERENCES Resenas(Resenas_ID)
);